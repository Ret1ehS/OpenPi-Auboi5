# Copy this file to config/local.env and adjust paths for the target machine.

OPENPI_RUNTIME_PYTHON=/home/niic/openpi/repo/.venv/bin/python
# JAX GPU memory (optional). Low VRAM % during infer is normal for small batches; raising it
# does not automatically make inference faster—watch GPU-Util / latency instead.
# OPENPI_JAX_PREALLOCATE=1
# OPENPI_JAX_MEM_FRACTION=0.5
# Jetson / tegra: `nvidia-smi` loads libnvidia-ml.so which needs libnvidia-rmapi-tegra.so.* in the
# same directory. If driver pieces drift (e.g. only .540.5.0 on disk but libnvidia-ml asks for
# .540.4.0), copy the .5.0 file to the .4.0 name under /usr/lib/aarch64-linux-gnu/nvidia/, then
# put this in ~/.bashrc (verified on Orin: nvidia-smi works with both dirs):
#   export LD_LIBRARY_PATH=/usr/lib/aarch64-linux-gnu/nvidia:/lib/aarch64-linux-gnu:${LD_LIBRARY_PATH}
# Optional: echo '/usr/lib/aarch64-linux-gnu/nvidia' | sudo tee /etc/ld.so.conf.d/nvidia-aarch64.conf && sudo ldconfig
OPENPI_SDK_ROOT=/home/niic/openpi/aubo_sdk/aubo_sdk-0.26.0-rc.3-Linux_aarch64+589233b

OPENPI_ROBOT_IP=192.168.1.100
OPENPI_ROBOT_PORT=30004
OPENPI_ROBOT_USER=aubo
OPENPI_ROBOT_PASSWORD=123456

OPENPI_GRIPPER_PORT=/dev/serial/by-id/usb-FTDI_FT232R_USB_UART_AB0LIYTU-if00-port0
OPENPI_GRIPPER_FALLBACK_PORT=/dev/ttyUSB3
OPENPI_FORCE_SENSOR_PORT=/dev/serial/by-id/usb-FTDI_FT232R_USB_UART_A10PHIEG-if00-port0
OPENPI_FORCE_SENSOR_FALLBACK_PORT=/dev/ttyUSB4

OPENPI_POLICY_CONFIG_NAME=pi05_aubo_agv_lora
OPENPI_CHECKPOINT_DIR=checkpoints/pi05_aubo_agv_lora/my_eighth_run/29999
OPENPI_POLICY_BACKEND=auto
# For PyTorch experiments, point this to a converted checkpoint directory containing model.safetensors.
# OPENPI_PYTORCH_CHECKPOINT_DIR=checkpoints/pi05_aubo_agv_lora_pytorch/my_eighth_run/29999
# OPENPI_PYTORCH_RUNTIME_PYTHON=/home/niic/openpi/miniforge3/envs/openpi-py310-torch/bin/python
# OPENPI_PYTORCH_DEVICE=cuda
# OPENPI_PYTORCH_TOKENIZER_MODEL=/home/niic/.cache/openpi/big_vision/paligemma_tokenizer.model
# OPENPI_PYTORCH_COMPILE_MODE=none
# Optional: TensorRT-compile the vision tower on Jetson for lower steady-state latency.
# First startup is slower because the engine must be built.
# OPENPI_PYTORCH_TRT_VISION=1
# OPENPI_PYTORCH_TRT_CACHE_DIR=/home/niic/.cache/openpi/torch_tensorrt/vision_embed
# JAX Pi0 flow-matching: fewer steps = lower latency, often worse quality. Upstream default is 10.
# OPENPI_SAMPLE_NUM_STEPS=5
# Optional: skip the local JAX subprocess probe (matmul + cuDNN conv). Use the same shell env as
# run_niic_jax_gpu.sh, or set OPENPI_JAX_PLATFORM=gpu to skip the probe entirely.
# OPENPI_SKIP_JAX_GPU_PROBE=1
# OPENPI_JAX_PLATFORM=gpu
OPENPI_K8S_NAMESPACE=wangrui
OPENPI_POLICY_LOCAL_PORT=8000
OPENPI_POLICY_REMOTE_PORT=8000
OPENPI_KUBECONFIG=support/kubeconfig.yaml

OPENPI_TASK_OBSERVER_ENABLE=false
OPENPI_TASK_OBSERVER_INTERVAL_S=5.0
OPENPI_TASK_OBSERVER_PYTHON=/home/niic/venvs/vllm-jp62-clean/bin/python
OPENPI_TASK_OBSERVER_MODEL=/home/niic/modelscope_models/google/gemma-4-E2B-it
OPENPI_TASK_OBSERVER_MAX_NEW_TOKENS=96
